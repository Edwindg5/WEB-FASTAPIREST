# Base de Datos PostgreSQL - CONFIGURACIÓN LOCAL
DATABASE_URL=postgresql://postgres:password@localhost:5432/cafe_monitoring_db
SQLALCHEMY_ECHO=True

# JWT
SECRET_KEY=tu-clave-super-segura-cambiar-en-produccion-local
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# FastAPI
APP_TITLE=API Web - Sistema Monitoreo Secado Café
APP_VERSION=1.0.0
APP_DESCRIPTION=Microservicio para monitoreo inteligente del secado de café
DEBUG=True

# CORS
FRONTEND_URL=http://localhost:4200

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60


# Logging
LOG_LEVEL=DEBUG

# Email (para reportes)
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USER=email@example.com
SMTP_PASSWORD=password
